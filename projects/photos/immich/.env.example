# Immich Environment Configuration
# 
# Copy this file to .env and configure your values
# CRITICAL: Configure secrets through Arcane UI (see .env.secrets for required secrets)

# ============================================================================
# User/Group Configuration
# ============================================================================
PUID=1027
PGID=100

# ============================================================================
# Storage Paths
# ============================================================================
CONFIG_STORAGE=/volume1/docker
MEDIA_STORAGE=/volume1/data
PHOTO_STORAGE=/volume1/photo

# ============================================================================
# Port Configuration
# ============================================================================
IMMICH_PORT=2283

# ============================================================================
# Database Configuration
# ============================================================================
DB_DATABASE_NAME=immich
DB_HOSTNAME=database
DB_USERNAME=postgres

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOSTNAME=redis

# ============================================================================
# Machine Learning Configuration
# ============================================================================
IMMICH_ML_URL=http://192.168.0.145:3003

# ============================================================================
# Resource Limits
# ============================================================================
IMMICH_MEMORY_LIMIT=1.5G
REDIS_MEMORY_LIMIT=256M
DB_MEMORY_LIMIT=768M

# ============================================================================
# SECRETS (Configure in Arcane UI - see .env.secrets)
# ============================================================================
# IMMICH_DB_PASSWORD - REQUIRED: PostgreSQL database password (generate strong password!)
# IMMICH_POSTGRES_PASSWORD - REQUIRED: Must match IMMICH_DB_PASSWORD
