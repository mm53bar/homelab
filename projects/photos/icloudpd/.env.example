# iCloudPD Environment Configuration
# 
# Copy this file to .env and configure your values
# CRITICAL: Configure secrets through Arcane UI (see .env.secrets for required secrets)

# ============================================================================
# User/Group Configuration
# ============================================================================
PUID=1027
PGID=100
TZ=America/Edmonton

# ============================================================================
# Storage Paths
# ============================================================================
CONFIG_STORAGE=/volume1/docker
PHOTO_STORAGE=/volume1/photo

# ============================================================================
# Download Configuration
# ============================================================================
FOLDER_STRUCTURE={:%Y/%m}
NOTIFICATION_DAYS=7
SYNC_INTERVAL=86400
DOWNLOAD_PATH=/icloud
SKIP_CHECK=false
AUTO_DELETE=true

# ============================================================================
# SECRETS (Configure in Arcane UI - see .env.secrets)
# ============================================================================
# ICLOUDPD_MIKE_APPLE_ID - REQUIRED: Apple ID for Mike
# ICLOUDPD_SHEILA_APPLE_ID - REQUIRED: Apple ID for Sheila
