# Calibre-Web-Automated Environment Configuration

# User/Group Configuration
PUID=1027
PGID=100
TZ=America/Edmonton

# Storage Paths
CONFIG_STORAGE=/volume1/docker
IMPORT_STORAGE=/volume1/data/import
MEDIA_STORAGE=/volume1/data

# Port Configuration
CALIBRE_PORT=8083

# Calibre Configuration
CALIBRE_MODS=lscr.io/linuxserver/mods:universal-calibre-v7.16.0
