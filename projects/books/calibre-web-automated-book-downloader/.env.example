# Shelfmark (Book Downloader) Environment Configuration
# Formerly: Calibre-Web-Automated-Book-Downloader

# User/Group Configuration
PUID=1027
PGID=100
TZ=America/Edmonton

# Port Configuration
FLASK_PORT=8084

# Flask Configuration
FLASK_DEBUG=false

# Book Configuration
INGEST_DIR=/books
BOOK_LANGUAGE=en

# Storage Paths
CONFIG_STORAGE=/volume1/docker
IMPORT_STORAGE=/volume1/data/import

# Note: Shelfmark has built-in Cloudflare bypass - no separate service needed!
