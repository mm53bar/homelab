# Books Stack Environment Variables
# Configuration for Calibre-Web-Automated and Shelfmark

# ============================================================================
# User/Group Configuration (inherited from global .env.global if set)
# ============================================================================
PUID=1027                    # User ID
PGID=100                     # Group ID
TZ=America/Edmonton          # Timezone

# ============================================================================
# Storage Paths (inherited from global .env.global if set)
# ============================================================================
CONFIG_STORAGE=/volume1/docker       # Application configs
MEDIA_STORAGE=/volume1/data          # Media files (books library)
IMPORT_STORAGE=/volume1/data/import  # Book download/import folder

# ============================================================================
# Port Configuration
# ============================================================================
# Default ports (only override if needed)
# CALIBRE_WEB_PORT=8083      # Calibre-Web-Automated (hardcoded in container)
SHELFMARK_PORT=8084          # Shelfmark downloader

# ============================================================================
# Shelfmark Configuration
# ============================================================================
FLASK_DEBUG=false            # Enable Flask debug mode
BOOK_LANGUAGE=en             # Preferred book language (en, es, fr, etc.)
