# Mealie (Recipe Manager) Environment Configuration

# User/Group Configuration
PUID=1027
PGID=100
TZ=America/Edmonton

# Storage Paths
CONFIG_STORAGE=/volume1/docker

# Port Configuration
MEALIE_PORT=9925

# Resource Limits
MEALIE_MEMORY_LIMIT=1000M

# Mealie Configuration
ALLOW_SIGNUP=true
MAX_WORKERS=1
WEB_CONCURRENCY=1
BASE_URL=https://mealie.backson.boo

# Version
MEALIE_VERSION=v1.0.0-RC1.1
