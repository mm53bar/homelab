# Paperless-NGX Environment Configuration
# 
# Copy this file to .env and configure your values
# CRITICAL: Configure secrets through Arcane UI (see .env.secrets for required secrets)

# ============================================================================
# User/Group Configuration
# ============================================================================
PUID=1027
PGID=100
TZ=America/Edmonton

# ============================================================================
# Storage Paths
# ============================================================================
CONFIG_STORAGE=/volume1/docker
DATA_STORAGE=/volume1/data
IMPORT_STORAGE=/volume1/data/import

# ============================================================================
# Port Configuration
# ============================================================================
PAPERLESS_PORT=8010

# ============================================================================
# Database Configuration
# ============================================================================
PAPERLESS_REDIS=redis://broker:6379

# ============================================================================
# OCR & Document Processing
# ============================================================================
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_FILENAME_FORMAT={created_year}/{correspondent}/{created} {title}
PAPERLESS_FILENAME_FORMAT_REMOVE_NONE=true

# ============================================================================
# Application Configuration
# ============================================================================
PAPERLESS_URL=https://paperless.backson.boo
PAPERLESS_ADMIN_USER=admin

# ============================================================================
# SECRETS (Configure in Arcane UI - see .env.secrets)
# ============================================================================
# PAPERLESS_SECRET_KEY - REQUIRED: Django secret key (generate new!)
# PAPERLESS_ADMIN_PASSWORD - REQUIRED: Admin user password (change from default!)
