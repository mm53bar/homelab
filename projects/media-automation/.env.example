# Environment variables configuration for Media Automation Stack
#
# Copy this file to .env and fill in your values
# These variables configure the entire media automation pipeline

# ============================================================================
# User/Group Configuration
# ============================================================================
PUID=1027                    # User ID (find with: id -u)
PGID=100                     # Group ID (find with: id -g)
TZ=America/Edmonton          # Timezone

# ============================================================================
# Storage Paths
# ============================================================================
CONFIG_STORAGE=/volume1/docker       # Application configs storage
MEDIA_STORAGE=/volume1/data          # Media files storage

# ============================================================================
# VPN Configuration (Gluetun)
# ============================================================================
# REQUIRED: Set your VPN credentials
OPENVPN_USER=your-vpn-username
OPENVPN_PASSWORD=your-vpn-password

# Optional: VPN provider settings (defaults shown)
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=openvpn
OPENVPN_CUSTOM_CONFIG=/gluetun/custom.conf

# ============================================================================
# Port Configuration
# ============================================================================
# All ports have sensible defaults, only override if needed

# Download Clients
QBITTORRENT_PORT=8200        # qBittorrent WebUI (proxied through Gluetun)
NZBGET_PORT=5678             # NZBGet WebUI

# Gluetun Proxy Ports
GLUETUN_PROXY_PORT=8888      # HTTP proxy
GLUETUN_SHADOWSOCKS_PORT=8388 # Shadowsocks

# qBittorrent Torrent Ports (exposed through Gluetun)
QBITTORRENT_PORT_TCP=6881
QBITTORRENT_PORT_UDP=6881

# Indexer & Management
PROWLARR_PORT=9696           # Indexer manager
JACKETT_PORT=9117            # Legacy indexer (optional)

# Media Management
SONARR_PORT=8989             # TV shows
RADARR_PORT=7878             # Movies
LIDARR_PORT=8686             # Music
READARR_PORT=8787            # Books/audiobooks
BAZARR_PORT=6767             # Subtitles

# ============================================================================
# FlareSolverr Configuration
# ============================================================================
LOG_LEVEL=info               # FlareSolverr log level (info, debug, warning, error)
